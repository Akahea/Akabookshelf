
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum BookType {
  ROMAN
  MANGA
  BD
  COMIC
  LIGHT_NOVEL
}

enum BookStatus {
  TO_READ
  READING
  FINISHED
  DROPPED
  LENT
}

model Book {
  id String @id @default(uuid())
  title String
  author String?
  type  BookType
  ownedVolumes Int @default(1)
  status BookStatus @default(TO_READ)
  rating Int?
  personalNotes String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}